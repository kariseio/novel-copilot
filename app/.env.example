# 이 파일을 app/.env 로 복사하고 키 값을 채우세요(.env 는 gitignore). config.py 가 import 시 .env 를
# 환경으로 로드합니다(SDK 가 os.environ 에서 직접 읽음). provider/모델 선택(llm_provider·gen_model)은
# .env 가 아니라 코드/A/B 에서 지정한다 — NOVEL_LLM_PROVIDER 는 쓰지 않는다.

# --- API 키 ---
OPENAI_API_KEY=sk-...        # 필수(임베딩/RAG + gpt-4.1 본문)
ANTHROPIC_API_KEY=           # Claude arm(윤문·문장력). 없으면 Claude 비교 생략
GEMINI_API_KEY=              # Gemini arm(한국어 자연스러움). GOOGLE_API_KEY= 로 넣어도 됨. 없으면 생략

# --- (선택) 기본값 오버라이드 ---
NOVEL_EMBED_MODEL=text-embedding-3-small
# NOVEL_GEN_MODEL=gpt-5.5                           # 프로즈/핫패스 기본(최신 플래그십). chat 변형 원하면 gpt-5.3-chat-latest
# NOVEL_WORLDGEN_MODEL=anthropic:claude-opus-4-8    # worldgen·bible(A/B 1위 claude). 빈값/키없으면 gen_model 폴백
# NOVEL_PLANNING_MODEL=gpt-5.5                       # 아크·에피·비트 설계(최신 추론 플래그십)
# NOVEL_DATA_DIR=D:\study\ai-web-novel\app\data
